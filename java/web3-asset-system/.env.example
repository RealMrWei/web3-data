# Web3 资产管理系统的合约地址配置
# 
# 使用方法：
# 1. 部署合约后，将实际地址填入下方对应位置
# 2. 或者在启动应用时通过环境变量传入
#    例如: ASSET_TOKEN_ADDRESS=0x... DEPOSIT_VAULT_ADDRESS=0x... java -jar app.jar

# ============================================
# 合约地址配置
# ============================================

# AssetToken 合约地址（ERC20 代币）
ASSET_TOKEN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# DepositVault 合约地址（充值金库）
DEPOSIT_VAULT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# WithdrawalManager 合约地址（提现管理）
WITHDRAWAL_MANAGER_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# ============================================
# RPC 节点配置
# ============================================

# Ethereum Sepolia 测试网 RPC
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# BNB Chain Testnet RPC
BNB_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Arbitrum Sepolia RPC
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# ============================================
# 私钥配置（生产环境必须使用 KMS）
# ============================================

# 管理员私钥（用于执行提现等操作）
WEB3_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ============================================
# 数据库配置
# ============================================

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/web3_asset?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# ============================================
# Redis 配置
# ============================================

SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# ============================================
# Kafka 配置
# ============================================

SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
